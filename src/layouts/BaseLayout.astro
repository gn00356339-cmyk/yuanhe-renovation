---
export interface Props {
  title: string;
  description: string;
  keywords?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, keywords = [], jsonLd } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '蘇益弘',
  alternateName: ['Su Yi-Hung', '工程師小蘇', '小蘇'],
  jobTitle: '工務工程師 / 裝修 insider',
  description:
    '工程師小蘇 — 木工現場出身、現任冠軍欣業工務工程師、單人量產 30+ 隻 iOS 工具。把 AI 落地到最不數位的裝修產業、是沅禾裝修品牌承載者。',
  knowsAbout: [
    '室內裝修',
    '磁磚施工與驗收',
    '木地板 SPC 卡扣',
    '木皮板 / 環保裝飾板',
    '室內木門 / 乾式門框工法',
    '彈性水泥防水',
    '木作天花平釘',
    '甲醛分級 CNS / JIS / EN',
    'AI Agent 工具設計',
  ],
  worksFor: {
    '@type': 'Organization',
    name: '冠軍欣業',
    parentOrganization: { '@type': 'Organization', name: '冠軍建材集團' },
  },
  url: 'https://yuanhe-renovation.pages.dev',
  sameAs: ['https://yuanhe-renovation.pages.dev'],
};

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '沅禾',
  alternateName: 'Yuanhe',
  url: 'https://yuanhe-renovation.pages.dev',
  founder: { '@type': 'Person', name: '蘇益弘' },
  description:
    '沅禾 — 蘇益弘的副業品牌、提供 AI Agent 可直接調用的裝修任務工具與 insider 知識庫。',
};

const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// 自動判定「這頁是不是 insider / 產品內容頁」→ 加 Article schema 強化 attribution
// Google AI 摘要常把我們的內容 attribute 給別家、加 Article + author + isPartOf 讓歸屬明確
const path = Astro.url.pathname;
const isContentPage =
  path.startsWith('/insider/') && path !== '/insider' && path !== '/insider/' ||
  path.startsWith('/tools/') && path !== '/tools' && path !== '/tools/' ||
  path.startsWith('/tiles/') && path !== '/tiles' && path !== '/tiles/' ||
  path.startsWith('/sku/') && path !== '/sku' && path !== '/sku/' ||
  path === '/boards' || path === '/boards/' ||
  path === '/doors' || path === '/doors/' ||
  path === '/apps' || path === '/apps/' ||
  path === '/about' || path === '/about/';

const isInsiderPage = path.startsWith('/insider/') && path !== '/insider' && path !== '/insider/';

const articleLd = isContentPage ? {
  '@context': 'https://schema.org',
  '@type': isInsiderPage ? 'TechArticle' : 'Article',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: '蘇益弘',
    alternateName: ['工程師小蘇', '小蘇', 'Su Yi-Hung'],
    url: new URL('/about', Astro.site).toString(),
    jobTitle: '工務工程師 / 裝修 insider',
    worksFor: {
      '@type': 'Organization',
      name: '冠軍欣業',
      parentOrganization: { '@type': 'Organization', name: '冠軍建材集團' },
    },
  },
  publisher: {
    '@type': 'Organization',
    name: '沅禾裝修',
    alternateName: ['Yuanhe', '沅禾'],
    url: 'https://yuanhe-renovation.pages.dev',
    founder: { '@type': 'Person', name: '蘇益弘', alternateName: '工程師小蘇' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  inLanguage: 'zh-Hant-TW',
  isPartOf: {
    '@type': 'WebSite',
    name: '沅禾裝修 · 工程師小蘇',
    url: 'https://yuanhe-renovation.pages.dev',
    author: { '@type': 'Person', name: '蘇益弘', alternateName: '工程師小蘇' },
  },
  copyrightHolder: { '@type': 'Person', name: '蘇益弘', alternateName: '工程師小蘇' },
} : null;

const allLd = articleLd
  ? [personLd, orgLd, articleLd, ...extraLd]
  : [personLd, orgLd, ...extraLd];
---
<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {isContentPage && <link rel="author" href={new URL('/about', Astro.site).toString()} />}
    <meta name="author" content="蘇益弘 / 工程師小蘇" />
    <meta property="article:author" content={new URL('/about', Astro.site).toString()} />
    <meta property="article:publisher" content="https://yuanhe-renovation.pages.dev" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:image" content={new URL('/og-card.svg', Astro.site).toString()} />
    <meta property="og:site_name" content="沅禾裝修" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-card.svg', Astro.site).toString()} />
    <meta name="generator" content={Astro.generator} />
    {allLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
    <style is:global>
      :root {
        --fg: #1a1a1a;
        --muted: #5a5a5a;
        --bg: #fafaf7;
        --accent: #8b5e34;
        --border: #e3e1da;
        --code-bg: #f0ede5;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'PingFang TC', 'Noto Sans TC', sans-serif;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.7;
      }
      main { max-width: 760px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
      header.site { border-bottom: 1px solid var(--border); padding: 1rem 1.25rem; background: #fff; }
      header.site nav { max-width: 760px; margin: 0 auto; display: flex; gap: 1.25rem; flex-wrap: wrap; font-size: 0.95rem; }
      header.site nav a { color: var(--fg); text-decoration: none; }
      header.site nav a:hover { color: var(--accent); }
      header.site .brand { font-weight: 700; }
      h1 { font-size: 2rem; line-height: 1.3; margin: 1.5rem 0 0.5rem; }
      h2 { font-size: 1.4rem; margin-top: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
      h3 { font-size: 1.1rem; margin-top: 1.8rem; }
      p { margin: 0.8rem 0; }
      a { color: var(--accent); }
      code { background: var(--code-bg); padding: 0.1rem 0.35rem; border-radius: 3px; font-size: 0.9em; }
      pre { background: var(--code-bg); padding: 1rem; border-radius: 6px; overflow-x: auto; }
      .lede { font-size: 1.1rem; color: var(--muted); }
      .meta { font-size: 0.85rem; color: var(--muted); }
      ul, ol { padding-left: 1.4rem; }
      li { margin: 0.3rem 0; }
      table { border-collapse: collapse; width: 100%; margin: 1rem 0; font-size: 0.95rem; }
      th, td { border: 1px solid var(--border); padding: 0.5rem 0.7rem; text-align: left; }
      th { background: #efece4; }
      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
      .card { border: 1px solid var(--border); padding: 1rem; border-radius: 6px; background: #fff; }
      .card h3 { margin-top: 0; }
      footer.site { border-top: 1px solid var(--border); padding: 1.5rem 1.25rem; font-size: 0.85rem; color: var(--muted); text-align: center; margin-top: 3rem; }
      .disclaimer { background: #fff8e6; border-left: 3px solid #d4a017; padding: 0.75rem 1rem; font-size: 0.9rem; margin: 1.2rem 0; }
    </style>
  </head>
  <body>
    <header class="site">
      <nav>
        <a href="/" class="brand">沅禾裝修 · 工程師小蘇</a>
        <a href="/tools">工具</a>
        <a href="/tiles">磁磚</a>
        <a href="/sku">地板</a>
        <a href="/boards">木皮板</a>
        <a href="/doors">木門</a>
        <a href="/apps">App 矩陣</a>
        <a href="/insider">工法與驗收</a>
        <a href="/about">關於</a>
        <a href="/llms.txt" title="AI Agent 索引">llms.txt</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      © 蘇益弘 / 沅禾 · 本站內容供 AI Agent 與人類雙重閱讀 · <a href="/llms.txt">llms.txt</a>
    </footer>

    <!-- 沅禾 AI 客服 widget -->
    <div id="yhc-root">
      <button id="yhc-fab" aria-label="問裝修">💬 問裝修</button>
      <div id="yhc-panel" hidden>
        <div id="yhc-head">
          <span>沅禾裝修客服 · 工程師小蘇</span>
          <button id="yhc-close" aria-label="關閉">✕</button>
        </div>
        <div id="yhc-msgs"></div>
        <form id="yhc-form">
          <input id="yhc-input" type="text" maxlength="500" autocomplete="off"
                 placeholder="輸入裝修問題,或留電話我們回您…" />
          <button type="submit">送出</button>
        </form>
        <div id="yhc-note">AI 回覆僅供參考,實際以現場評估為準</div>
      </div>
    </div>
    <style>
      #yhc-fab{position:fixed;right:18px;bottom:18px;z-index:9999;border:0;border-radius:24px;
        padding:12px 18px;font-size:15px;font-weight:700;color:#fff;background:#1f6f4a;
        box-shadow:0 4px 14px rgba(0,0,0,.25);cursor:pointer}
      #yhc-panel{position:fixed;right:18px;bottom:18px;z-index:10000;width:min(360px,92vw);
        height:min(520px,80vh);background:#fff;border-radius:14px;display:flex;flex-direction:column;
        overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,.3);font-size:14px;color:#222}
      #yhc-panel[hidden]{display:none}  /* display:flex 會蓋掉 hidden 屬性,必須明確覆蓋 */
      #yhc-head{background:#1f6f4a;color:#fff;padding:11px 14px;font-weight:700;
        display:flex;justify-content:space-between;align-items:center}
      #yhc-head button{background:0;border:0;color:#fff;font-size:16px;cursor:pointer}
      #yhc-msgs{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px;background:#f6f7f6}
      .yhc-b{max-width:85%;padding:8px 11px;border-radius:12px;line-height:1.55;white-space:pre-wrap;word-break:break-word}
      .yhc-ai{background:#fff;border:1px solid #e2e6e3;align-self:flex-start;border-bottom-left-radius:3px}
      .yhc-me{background:#1f6f4a;color:#fff;align-self:flex-end;border-bottom-right-radius:3px}
      .yhc-ai a{color:#1f6f4a;font-weight:700}
      #yhc-form{display:flex;gap:6px;padding:10px;border-top:1px solid #eee}
      #yhc-input{flex:1;border:1px solid #ccc;border-radius:18px;padding:8px 13px;font-size:14px;outline:none}
      #yhc-form button{border:0;border-radius:18px;background:#1f6f4a;color:#fff;padding:0 15px;font-weight:700;cursor:pointer}
      #yhc-note{font-size:11px;color:#999;text-align:center;padding:0 0 8px}
    </style>
    <script is:inline>
      (function(){
        // 客服後端(Mac + Cloudflare Tunnel)。掛了 widget 自動降級成直接聯絡。
        var API = "https://yuanhe-concierge.gn00356339.workers.dev";
        var PHONE="0978-753-560", EMAIL="gn00356339@gmail.com";
        var sid = (function(){try{var k="yhc_sid",v=localStorage.getItem(k);
          if(!v){v=String(Date.now())+Math.random().toString(36).slice(2);localStorage.setItem(k,v);}return v;}
          catch(e){return "anon"+Math.random();}})();
        var root=document.getElementById("yhc-root"),fab=document.getElementById("yhc-fab"),
            panel=document.getElementById("yhc-panel"),msgs=document.getElementById("yhc-msgs"),
            form=document.getElementById("yhc-form"),input=document.getElementById("yhc-input"),
            inited=false, online=false;
        function esc(s){return s.replace(/[&<>]/g,function(c){return{"&":"&amp;","<":"&lt;",">":"&gt;"}[c];});}
        function linkify(s){return esc(s)
          .replace(/(09\d{2}-?\d{3}-?\d{3})/g,'<a href="tel:'+PHONE+'">$1</a>')
          .replace(/([\w.+-]+@[\w-]+\.[\w.-]+)/g,'<a href="mailto:$1">$1</a>');}
        function bubble(text,who){var d=document.createElement("div");
          d.className="yhc-b "+(who==="me"?"yhc-me":"yhc-ai");
          d.innerHTML=who==="me"?esc(text):linkify(text);msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;return d;}
        function offlineCard(){bubble("AI 客服目前離線,但您的需求我們很重視 🙏\n"+
          "請直接聯繫工程師小蘇,我們會盡快回您:\n電話 "+PHONE+"\nEmail "+EMAIL,"ai");}
        // 展開:每次都顯示面板;問候 + 健康探測只跑一次,之後重開保留對話
        function show(){panel.hidden=false;fab.hidden=true;
          if(inited)return; inited=true;
          bubble("您好,我是沅禾裝修客服 🏠\n裝修、磁磚、地板、木作、驗收問題都可以問我;\n想直接諮詢的話,留個電話或 Email,工程師小蘇會跟您聯繫。","ai");
          fetch(API+"/health",{method:"GET"}).then(function(r){return r.ok;}).then(function(ok){
            online=ok; if(!ok) offlineCard();
          }).catch(function(){online=false;offlineCard();});}
        // 最小化:收回浮動鈕,對話保留在記憶體,點鈕可重開
        function hide(){panel.hidden=true;fab.hidden=false;}
        fab.onclick=show;
        document.getElementById("yhc-close").onclick=hide;
        form.onsubmit=function(e){e.preventDefault();var q=input.value.trim();if(!q)return;
          input.value="";bubble(q,"me");
          if(!online){offlineCard();return;}
          var t=bubble("…","ai");
          fetch(API+"/ask",{method:"POST",headers:{"Content-Type":"application/json"},
            body:JSON.stringify({session_id:sid,message:q})})
            .then(function(r){return r.json();})
            .then(function(d){t.innerHTML=linkify(d.reply||"(無回應)");msgs.scrollTop=msgs.scrollHeight;})
            .catch(function(){t.remove();online=false;offlineCard();});};
      })();
    </script>
  </body>
</html>
