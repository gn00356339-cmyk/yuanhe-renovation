---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = '大匠 DJ 系列 — 10 款含洞石紋｜冠軍欣業｜沅禾裝修';
const description = '大匠 DJ 系列、SPC 卡扣地板含洞石紋路設計、共 10 款:DJ0801-DJ0810。';
---
<BaseLayout title={title} description={description} keywords={['大匠 DJ','洞石地板','石紋地板','SPC 卡扣','冠軍欣業']}>
  <h1>大匠 DJ — 含洞石紋路</h1>
  <p class="lede">SPC 卡扣地板的石紋系列、共 10 款、追求石材視覺重量。</p>

  <h2>SKU 清單</h2>
  <p>DJ0801, DJ0802, DJ0803, DJ0804, DJ0805, DJ0806, DJ0807, DJ0808, DJ0809, DJ0810</p>

  <h2>系列特色</h2>
  <ul>
    <li><strong>洞石紋</strong> — UV 印刷層採洞石、大理石紋路</li>
    <li><strong>視覺重量</strong> — 比 MB 系列更具份量、適合客廳、商空</li>
    <li><strong>耐磨</strong> — AC5 等級、適合高使用率場域</li>
  </ul>

  <h2>適用場景</h2>
  <ul>
    <li>客廳主視覺、商空、店面</li>
    <li>想要石材視覺但預算 / 重量考量不選真石材</li>
