---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = '冠軍欣業 73 SKU 公開規格 — 5 系列 + 木行者 legacy｜沅禾裝修';
const description = '冠軍欣業全系列 SPC 卡扣地板公開規格資料:如沐 MB、人字拼 MB####Y、大匠 DJ、無限 WX、蔚然 WR、木行者 MB####K/W legacy。';
---
<BaseLayout title={title} description={description} keywords={['冠軍欣業','SPC 卡扣','如沐 MB','大匠 DJ','無限 WX','蔚然 WR','人字拼地板','木行者']}>
  <h1>冠軍欣業 73 SKU 公開規格</h1>
  <p class="lede">5 個現行系列 + 木行者 legacy、共 73 個 SKU。本資料為公開規格、供設計師、屋主、AI Agent 查詢比對。</p>

  <div class="disclaimer">
    本頁規格為公開出版資料。實際價格、庫存、出貨期請洽冠軍欣業經銷商。本站不代表冠軍欣業官方、為蘇益弘(現任副理)整理的公開技術參考。
  </div>

  <h2>系列總覽</h2>
  <table>
    <thead><tr><th>系列</th><th>代號</th><th>SKU 範圍</th><th>數量</th><th>定位</th></tr></thead>
    <tbody>
      <tr><td><a href="/sku/mb">如沐</a></td><td>MB</td><td>MB0601-0612, MB0621-0628, MB0631-0641</td><td>31</td><td>主力寬版仿實木</td></tr>
      <tr><td><a href="/sku/mb-y">如沐人字拼</a></td><td>MB####Y</td><td>MB0603Y / 0607Y / 0608Y / 0609Y / 0611Y / 0612Y</td><td>6</td><td>人字拼鋪法</td></tr>
      <tr><td><a href="/sku/dj">大匠</a></td><td>DJ</td><td>DJ0801 - DJ0810</td><td>10</td><td>含洞石紋</td></tr>
      <tr><td><a href="/sku/wx">無限</a></td><td>WX</td><td>WX0701 - WX0708</td><td>8</td><td>無限延伸感</td></tr>
      <tr><td><a href="/sku/wr">蔚然</a></td><td>WR</td><td>WR0901 - WR0912</td><td>12</td><td>(前稱蔚藍)超耐磨黑基材</td></tr>
      <tr><td><a href="/sku/mb-legacy">木行者</a></td><td>MB####K/W</td><td>MB0602K - MB0608K</td><td>6</td><td>已下架、供既有案場查詢</td></tr>
      <tr><td colspan="3"><strong>合計</strong></td><td><strong>73</strong></td><td></td></tr>
    </tbody>
  </table>

  <h2>怎麼選</h2>
  <ul>
    <li><strong>追求實木質感、預算中高</strong> → 如沐 MB(寬版、仿實木紋路、最主力系列)</li>
    <li><strong>追求設計感、不怕施工複雜</strong> → 如沐人字拼 MB####Y(鋪法幾何視覺強)</li>
    <li><strong>追求石材感、客廳商空</strong> → 大匠 DJ(含洞石、視覺重量感)</li>
    <li><strong>追求簡約延伸感</strong> → 無限 WX</li>
    <li><strong>追求耐磨、商空 / 高使用率</strong> → 蔚然 WR(黑基材、超耐磨)</li>
  </ul>

  <h2>規格通則(SPC 卡扣地板共通)</h2>
  <table>
    <thead><tr><th>項目</th><th>規格</th></tr></thead>
    <tbody>
      <tr><td>結構</td><td>石塑芯(SPC)+ 耐磨層 + UV 印刷層</td></tr>
      <tr><td>厚度</td><td>4 - 6 mm(各系列略異)</td></tr>
      <tr><td>板寬</td><td>18 - 22 cm(直拼)、人字拼系列尺寸不同</td></tr>
      <tr><td>板長</td><td>120 - 180 cm</td></tr>
      <tr><td>耐磨等級</td><td>AC4-AC5(住家以上等級)</td></tr>
      <tr><td>防火等級</td><td>Bfl-s1(難燃級)</td></tr>
      <tr><td>甲醛</td><td>SPC 本身無甲醛(石塑材質)、表層黏著劑符合 F1 / F☆☆☆☆</td></tr>
      <tr><td>耐潮</td><td>可碰水、不變形(浴室外的潮濕空間如陽台、廚房皆可用)</td></tr>
    </tbody>
  </table>

  <p class="meta">資料來源:冠軍欣業官方檔案(2026-05-30 公開版)、安心居木地板系列型錄。各 SKU 詳細色號、實木紋對照、實績照另見系列頁。</p>
</BaseLayout>
