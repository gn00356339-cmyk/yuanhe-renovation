---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = '如沐人字拼 MB####Y — 6 款｜冠軍欣業｜沅禾裝修';
const description = '如沐人字拼系列、設計感強烈的人字拼鋪法地板、共 6 款:MB0603Y / MB0607Y / MB0608Y / MB0609Y / MB0611Y / MB0612Y。';
---
<BaseLayout title={title} description={description} keywords={['人字拼地板','MB####Y','Herringbone','設計地板','冠軍欣業']}>
  <h1>如沐人字拼 MB####Y</h1>
  <p class="lede">人字拼鋪法的設計感系列、共 6 款、追求歐式經典視覺。</p>

  <h2>SKU 清單</h2>
  <ul>
    <li>MB0603Y</li>
    <li>MB0607Y</li>
    <li>MB0608Y</li>
    <li>MB0609Y</li>
    <li>MB0611Y</li>
    <li>MB0612Y</li>
  </ul>
  <p class="meta">色號對應如沐 MB 同號色、但板材尺寸與鋪法為人字拼專用。</p>

  <h2>人字拼鋪法注意</h2>
  <ul>
    <li><strong>損耗高</strong>:12-18%、比直鋪多一倍(切角、配紋、首尾收頭)</li>
    <li><strong>板長較短</strong>:人字拼專用尺寸、長度通常比 MB 直拼短</li>
    <li><strong>施工難度高</strong>:需放樣對角線、抓首根板的位置、不適合新手師傅</li>
    <li><strong>視覺重量大</strong>:小坪數(< 8 坪)使用人字拼會壓縮感、建議中大坪數</li>
  </ul>

  <h2>適用場景</h2>
  <ul>
    <li>追求歐式經典、北歐設計風</li>
    <li>客廳主視覺區、玄關</li>
    <li>商空、咖啡店、選物店</li>
  </ul>

  <p><a href="/sku">← 回 5 系列總覽</a></p>
</BaseLayout>
