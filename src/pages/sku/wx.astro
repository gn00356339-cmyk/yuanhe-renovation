---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = '無限 WX 系列 — 8 款 SPC 卡扣地板｜冠軍欣業｜沅禾裝修';
const description = '無限 WX 系列、SPC 卡扣地板簡約延伸感設計、共 8 款:WX0701-WX0708。';
---
<BaseLayout title={title} description={description} keywords={['無限 WX','簡約地板','SPC 卡扣','冠軍欣業']}>
  <h1>無限 WX — 簡約延伸感</h1>
  <p class="lede">SPC 卡扣地板簡約系列、共 8 款、追求視覺延伸與留白。</p>

  <h2>SKU 清單</h2>
  <p>WX0701, WX0702, WX0703, WX0704, WX0705, WX0706, WX0707, WX0708</p>

  <h2>系列特色</h2>
  <ul>
    <li><strong>低調木紋</strong> — 紋路較淺、整體均勻、降低視覺干擾</li>
    <li><strong>適合留白設計</strong> — 配 Muji / 北歐 / 日式禪風</li>
    <li><strong>大坪數延伸</strong> — 長板配合低調紋路、視覺更顯寬廣</li>
  </ul>

  <h2>適用場景</h2>
  <ul>
    <li>追求簡約、留白風格</li>
