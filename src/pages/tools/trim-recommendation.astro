---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = '收邊條配對 — 卡扣地板四件套選用｜沅禾裝修';
const description = '卡扣地板(SPC / 超耐磨)收邊條四件套:起步條、T 字條、L 條、一字條,按場景情境推薦。';
---
<BaseLayout title={title} description={description} keywords={['收邊條','卡扣地板','起步條','T 字條','L 條','一字條','平壓條']}>
  <h1>收邊條配對</h1>
  <p class="lede">卡扣地板四件套 — 不同場景用不同條、別混為一談。</p>

  <h2>四件套對照</h2>
  <table>
    <thead><tr><th>類型</th><th>用途</th><th>形狀特徵</th><th>典型場景</th></tr></thead>
    <tbody>
      <tr>
        <td><strong>起步條</strong></td>
        <td>地板第一排靠牆 / 第一排起點</td>
        <td>單側卡溝、另一側壓條</td>
        <td>沿牆面鋪設第一片、留伸縮縫</td>
      </tr>
      <tr>
        <td><strong>T 字條</strong></td>
        <td>兩塊等高地板銜接</td>
        <td>T 型剖面、跨在兩片之間</td>
        <td>客廳 ↔ 臥室(不同房間、同高度木地板)、不同色木地板分界</td>
      </tr>
      <tr>
        <td><strong>L 條(收口條)</strong></td>
        <td>地板邊緣外露、無對應材銜接</td>
        <td>L 型剖面、收住地板邊緣</td>
        <td>樓梯踏階前緣、地板末端遇到牆角、收住外露切邊</td>
      </tr>
      <tr>
        <td><strong>一字條(平壓條)</strong></td>
        <td>木地板 ↔ 異材(磁磚 / 大理石 / 水泥粉光)</td>
        <td>扁平、覆蓋兩材銜接縫</td>
        <td>玄關磁磚 ↔ 客廳木地板、廚房 ↔ 餐廳</td>
      </tr>
    </tbody>
  </table>

  <h2>常見配對情境</h2>
  <table>
    <thead><tr><th>情境</th><th>用哪一條</th><th>備註</th></tr></thead>
    <tbody>
      <tr><td>玄關磁磚 → 客廳木地板</td><td>一字條</td><td>異材銜接、覆蓋伸縮縫</td></tr>
      <tr><td>客廳木地板 → 臥室木地板(同高度)</td><td>T 字條</td><td>分隔房間、避免一整片連動</td></tr>
      <tr><td>木地板鋪到一半、邊緣懸空(如樓梯)</td><td>L 條</td><td>收住邊緣、避免卡扣外露</td></tr>
      <tr><td>地板靠牆第一排</td><td>起步條 + 踢腳板</td><td>留 8-10mm 伸縮縫、踢腳板蓋住</td></tr>
      <tr><td>木地板 → 浴室(高低差)</td><td>L 條 + 門檻石</td><td>浴室高度通常較低、需門檻分水</td></tr>
      <tr><td>木地板 → 廚房磁磚(同高度)</td><td>一字條</td><td>無高低差時最美觀</td></tr>
    </tbody>
  </table>

  <h2>選用注意</h2>
  <ul>
    <li><strong>顏色配對</strong>:收邊條多為鋁合金或塑膠、可選擇接近地板色或對比銀 / 黑</li>
    <li><strong>厚度配對</strong>:T 字條 / 一字條須對齊兩側材厚、避免突起絆腳</li>
    <li><strong>伸縮縫</strong>:卡扣地板靠牆邊必留 8-10mm 伸縮縫、收邊條 / 踢腳板覆蓋</li>
    <li><strong>長度</strong>:常見 90cm 或 270cm 一根、超長空間需接條(接縫處放家具下較好)</li>
  </ul>

  <p>計算地板總用量請見:<a href="/tools/flooring-estimator">木地板估算</a></p>
</BaseLayout>
